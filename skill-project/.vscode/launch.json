{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flask Backend",
      "type": "debugpy",
      "request": "launch",
      "module": "flask",
      "env": { "FLASK_APP": "app.py", "FLASK_ENV": "development" },
      "args": ["run", "--port", "3801"],
      "cwd": "${workspaceFolder}/backend"
    },
    {
      "name": "Run Tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests/", "-v"],
      "cwd": "${workspaceFolder}"
    }
  ]
}
